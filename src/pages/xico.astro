---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import { site } from "../data/site";

const xicoSections = [
  {
    id: "pueblo-magico",
    title: "PUEBLO MÁGICO",
    description:
      "El 6 de diciembre de 2011 Xico fue declarado Pueblo Mágico. Nombramiento del gobierno federal donde se le reconoce a Xico sus atributos simbólicos, imagen urbana, gastronomía, leyendas, historia, hechos trascendentes y una magia que emana en cada una de sus tradiciones y manifestaciones socio-culturales que significan hoy día, una gran oportunidad para el aprovechamiento turístico.",
    images: [
      "/assets/2017_07_slide_tradiciones_1.jpg",
      "/assets/2017_07_slide_tradiciones_2.jpg",
      "/assets/2017_07_slide_tradiciones_3.jpg",
    ],
  },
  {
    id: "gastronomia",
    title: "GASTRONOMÍA",
    description:
      "Xico cuenta con una gran riqueza gastronómica en la cual se encuentra reflejado el sincretismo cultural entre la cultura indígena y española. Dentro de los platillos gastronómicos destacan: el mole, el café, el pan, los licores de mora y verde, el xonequi, los xocos, los chiles rellenos, los tamales canarios, entre otros platillos llenos de colores, olores y sabores que son un deleite al paladar.",
    images: [
      "/assets/2017_07_slide_gastronomia_1.jpg",
      "/assets/2017_07_slide_tradiciones_4.jpg",
      "/assets/2017_07_slide_tradiciones_5.jpg",
    ],
  },
  {
    id: "fiestas",
    title: "FIESTAS Y TRADICIONES",
    description:
      "Uno elemento muy importante que integra todas estas manifestaciones culturales es Santa María Magdalena, patrona del Pueblo Mágico de Xico. En las danzas que se dan durante las procesiones de Santa María Magdalena y de los santos pertenecientes a las más de 30 capillas del pueblo, podemos observar la ideología del pueblo en una representación vistosa, colorida y llena simbolismos de la cultura indígena y española.",
    celebrations: [
      "Semana Santa.",
      "Fiestas patronales en honor a Santa María Magdalena. Todo el mes de Julio. Días más importantes del 19 al 22 de Julio.",
      "Todos Santos. 1 y 2 de Noviembre.",
      "Fiestas Decembrinas. 16 de Diciembre al 2 de Enero. Días más importantes: 24, 25 y 31 de Diciembre.",
    ],
    images: [
      "/assets/2017_07_slide_tradiciones_6.jpg",
      "/assets/2017_07_slide_tradiciones_7.jpg",
      "/assets/2017_07_slide_tradiciones_8.jpg",
    ],
  },
];

const introImages = [
  "/assets/2017_07_xico-3-768x515.jpg",
  "/assets/2017_07_slide_tradiciones_1.jpg",
  "/assets/2017_07_slide_tradiciones_2.jpg",
];
---

<BaseLayout
  title={`Xico, Pueblo Mágico - ${site.name}`}
  description="Xico, Pueblo Mágico de Veracruz: tradiciones, gastronomía, fiestas y naturaleza en las faldas del Cofre de Perote."
  canonicalPath="/xico/"
>
  <main>
    <PageHero title="XICO" image="/assets/2017_07_xico-3-768x515.jpg" />

    <section class="section xico-intro">
      <div class="container-x">
        <div class="xico-intro__grid">
          <div class="xico-intro__content">
            <SectionIntro
              titleText="Un Pueblo con Identidad Única"
              lead="Alegre poblado en el centro del estado de Veracruz situado sobre las faldas del Cofre de Perote y a 18 km de Xalapa, capital del estado. Xico posee un clima benevolente, rodeado de hermosos paisajes montañosos, miradores con increíbles vistas a caídas de agua cristalina y fincas que guardan el mejor café de altura de la región."
            />
            <p class="xico-intro__paragraph">
              El soporte histórico de Xico lo vemos reflejado en sus casonas coloniales, calles
              empedradas, parques, plazoletas, museos, la parroquia de Santa María Magdalena, las
              más de 30 capillas, así como sus fiestas y tradiciones, que hacen de Xico, un pueblo
              con identidad única.
            </p>
          </div>

          <div class="xico-intro__gallery">
            {
              introImages.map((src, i) => (
                <figure class={`xico-intro__item xico-intro__item--${i + 1}`}>
                  <img src={src} alt={`Xico ${i + 1}`} class="xico-intro__image" loading="lazy" />
                </figure>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {
      xicoSections.map((section, index) => (
        <section
          class={`section xico-section xico-section--${index % 2 === 0 ? "normal" : "reverse"}`}
        >
          <div class="container-x">
            <div class="xico-section__grid">
              <div class="xico-section__content">
                <p class="xico-section__eyebrow">Descubre Xico</p>
                <h2 class="font-display text-2xl md:text-3xl tracking-[0.1em] uppercase text-accent-dark text-center md:text-left mb-4 mt-0">
                  {section.title}
                </h2>
                <SectionDivider />
                <p class="xico-section__description">{section.description}</p>

                {section.celebrations && (
                  <div class="xico-section__celebrations">
                    <p class="xico-section__celebrations-title">
                      Celebraciones más representativas:
                    </p>
                    <ul class="xico-section__celebrations-list">
                      {section.celebrations.map((item) => (
                        <li class="xico-section__celebration-item">
                          <span class="xico-section__celebration-icon">✦</span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <div class="xico-section__gallery">
                {section.images.map((src, i) => (
                  <figure class={`xico-section__item xico-section__item--${i + 1}`}>
                    <img
                      src={src}
                      alt={`${section.title} ${i + 1}`}
                      class="xico-section__image"
                      loading="lazy"
                    />
                  </figure>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))
    }

    <section class="section xico-cta-section">
      <div class="container-x">
        <div class="xico-cta">
          <h2
            class="font-display text-3xl md:text-4xl leading-tight font-normal tracking-tighter text-ink-dark text-center mb-4 mt-0"
          >
            Visita Xico
          </h2>
          <p class="xico-cta__lead">
            Permítenos ser tu hospedaje en este Pueblo Mágico. En Las Magdalenas te esperamos con la
            calidez de siempre.
          </p>
          <a href="/contacto/" class="btn"> Reservar Ahora </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .xico-intro {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 15% 10%, rgba(231, 173, 68, 0.18), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 100%);
  }

  .xico-intro::before {
    content: "";
    position: absolute;
    inset: 2rem;
    pointer-events: none;
    border: 1px solid rgba(114, 48, 95, 0.12);
  }

  .xico-intro__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 2.5rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .xico-intro__content {
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 1.5rem 3rem rgba(84, 63, 63, 0.09);
  }

  .xico-intro__paragraph {
    max-width: 3xl;
    margin: 1.5rem auto 0;
    color: #4a4a4a;
    line-height: 1.7;
    text-align: center;
  }

  .xico-intro__gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .xico-intro__item {
    position: relative;
    overflow: hidden;
    margin: 0;
    background: #1d1d1d;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.14);
  }

  .xico-intro__item--1 {
    grid-column: span 2;
    grid-row: span 2;
    min-height: 18rem;
  }

  .xico-intro__item--2,
  .xico-intro__item--3 {
    min-height: 10rem;
  }

  .xico-intro__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .xico-intro__item:hover .xico-intro__image {
    transform: scale(1.04);
  }

  .xico-section {
    position: relative;
    overflow: hidden;
  }

  .xico-section:nth-child(odd) {
    background: #fff;
  }

  .xico-section:nth-child(even) {
    background:
      radial-gradient(circle at 85% 8%, rgba(231, 173, 68, 0.14), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 100%);
  }

  .xico-section__grid {
    display: grid;
    gap: 2rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .xico-section__content {
    padding: 1.5rem;
  }

  .xico-section__eyebrow {
    margin: 0 0 0.75rem;
    color: #72305f;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  .xico-section__description {
    margin: 1rem 0 0;
    color: #4a4a4a;
    line-height: 1.7;
    text-align: center;
  }

  .xico-section__celebrations {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: rgba(247, 244, 242, 0.86);
    border: 1px solid rgba(231, 173, 68, 0.22);
  }

  .xico-section__celebrations-title {
    margin: 0 0 0.75rem;
    color: #72305f;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-align: center;
    text-transform: uppercase;
  }

  .xico-section__celebrations-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .xico-section__celebration-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: #4a4a4a;
    font-size: 0.875rem;
    line-height: 1.6;
    border-bottom: 1px solid rgba(226, 220, 210, 0.5);
  }

  .xico-section__celebration-item:last-child {
    border-bottom: 0;
  }

  .xico-section__celebration-icon {
    color: #e7ad44;
    font-size: 0.75rem;
    line-height: 1.6;
    flex-shrink: 0;
  }

  .xico-section__gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .xico-section__item {
    position: relative;
    overflow: hidden;
    margin: 0;
    background: #1d1d1d;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.12);
  }

  .xico-section__item--1 {
    grid-column: span 2;
    grid-row: span 2;
    min-height: 16rem;
  }

  .xico-section__item--2,
  .xico-section__item--3 {
    min-height: 10rem;
  }

  .xico-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .xico-section__item:hover .xico-section__image {
    transform: scale(1.04);
  }

  .xico-cta-section {
    background: #f7f4f2;
  }

  .xico-cta {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    text-align: center;
    background: #fff;
    border: 1px solid rgba(231, 173, 68, 0.22);
    box-shadow: 0 1.5rem 3rem rgba(84, 63, 63, 0.08);
  }

  .xico-cta__lead {
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: #4a4a4a;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .xico-intro__grid {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
      gap: 2.5rem;
    }

    .xico-intro__content {
      padding: 3rem 2rem;
    }

    .xico-intro__item--1 {
      min-height: 22rem;
    }

    .xico-intro__item--2,
    .xico-intro__item--3 {
      min-height: 12rem;
    }

    .xico-section__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 2.5rem;
    }

    .xico-section--reverse .xico-section__content {
      order: 2;
    }

    .xico-section--reverse .xico-section__gallery {
      order: 1;
    }

    .xico-section__content {
      padding: 2rem;
    }

    .xico-section__eyebrow {
      text-align: left;
    }

    .xico-section__description {
      text-align: left;
    }

    .xico-section__celebrations-title {
      text-align: left;
    }

    .xico-section__item--1 {
      min-height: 20rem;
    }

    .xico-section__item--2,
    .xico-section__item--3 {
      min-height: 12rem;
    }

    .xico-cta {
      padding: 4rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .xico-intro__item--1 {
      min-height: 26rem;
    }

    .xico-section__item--1 {
      min-height: 24rem;
    }
  }
</style>
