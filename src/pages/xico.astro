---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../data/site";

const xicoImages = [
  "/assets/2017_07_xico-3-768x515.jpg",
  "/assets/2017_07_slide_tradiciones_1.jpg",
  "/assets/2017_07_slide_tradiciones_2.jpg",
  "/assets/2017_07_slide_tradiciones_3.jpg",
  "/assets/2017_07_slide_cafeteria_1-1.jpg",
  "/assets/2017_07_slide_cafeteria_2-1.jpg",
];
---

<BaseLayout
  title={`Xico - ${site.name}`}
  description="Xico, Pueblo Mágico de Veracruz. Tradiciones, gastronomía y naturaleza."
  canonicalPath="/xico/"
>
  <main>
    <PageHero title="XICO" image={xicoImages[0]} />

    <section class="section">
      <div class="container-x">
        <SectionIntro
          lead="Xico es un Pueblo Mágico rodeado de montañas, cafetales y tradiciones. Sus calles empedradas, su gastronomía y su gente hacen de este lugar un destino único para descansar y reconectar."
        />
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {xicoImages.map((src) => <img src={src} alt="Xico" class="w-full aspect-[4/3] object-cover" loading="lazy" />)}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
