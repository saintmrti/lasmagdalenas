---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTitle from "../components/PageTitle.astro";
import SectionIntro from "../components/SectionIntro.astro";
import PromoGrid from "../components/PromoGrid.astro";
import { events, site } from "../data/site";

const baseUrl = site.url;

const offersLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Promociones y paquetes",
  itemListElement: events.map((promo, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Offer",
      name: promo.title,
      description: promo.text,
      url: `${baseUrl}/promociones/`,
      image: promo.image.startsWith("http") ? promo.image : `${baseUrl}${promo.image}`,
    },
  })),
};
---

<BaseLayout
  title={`Promociones y Paquetes | ${site.name}`}
  description="Promociones especiales para tu estancia en Xico, Veracruz. Paquetes de hospedaje, reuniones, eventos y ocasiones especiales en Las Magdalenas Hotel Boutique."
  canonicalPath="/promociones/"
  jsonLd={[offersLd]}
>
  <main>
    <PageTitle title="PROMOCIONES" />

    <section class="section">
      <div class="container-x">
        <SectionIntro
          lead="Aproveche al máximo su estancia en Xico con estas exclusivas promociones."
        />
        <PromoGrid />
        <p class="max-w-3xl my-8 mx-auto text-ink-soft italic text-center">
          *Aplican restricciones y vigencias en nuestras promociones. Por favor póngase en contacto
          con nosotros. Será un placer informarle de nuestros paquetes y tarifas especiales para
          individuales, parejas o grupos.
        </p>
        <a href="/contacto/" class="btn">CONTÁCTANOS</a>
      </div>
    </section>
  </main>
</BaseLayout>
