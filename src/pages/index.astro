---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSlider from "../components/HeroSlider.astro";
import SectionIntro from "../components/SectionIntro.astro";
import RoomGrid from "../components/RoomGrid.astro";
import EventsRows from "../components/EventsRows.astro";
import { homeContent, images, events, site } from "../data/site";

const hotelLd = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  name: site.name,
  description:
    "Hotel boutique en Xico, Veracruz, ubicado en una casona colonial del siglo XIX. Habitaciones, restaurante, eventos y experiencias en un Pueblo Mágico.",
  url: site.url,
  image: new URL(site.socialImage, site.url).toString(),
  telephone: site.phoneTel,
  email: site.email,
  priceRange: "$$",
  starRating: { "@type": "Rating", ratingValue: "4" },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hidalgo 123, Colonia Centro",
    addressLocality: "Xico",
    addressRegion: "Veracruz",
    postalCode: "91240",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
};
---

<BaseLayout
  title={`${site.name} | Hotel Boutique en Xico, Veracruz`}
  description="Hotel boutique en Xico, Veracruz. Hospedaje en una casona colonial del siglo XIX con habitaciones, restaurante, eventos y experiencias en un Pueblo Mágico. Hoteles y hospedaje en Xico, Veracruz."
  canonicalPath="/"
  jsonLd={[hotelLd]}
>
  <main>
    <h1 class="sr-only">Las Magdalenas Hotel Boutique en Xico, Veracruz</h1>
    <HeroSlider slides={images.heroSlides} alt={site.name} height="70vh" />
    <section class="section">
      <div class="container-x">
        <SectionIntro
          titleImage={images.hotelTitle}
          titleText={homeContent.hotel.title}
          lead={homeContent.hotel.description}
        />
        <p class="max-w-2xl mx-auto mb-8 text-zinc-600 text-sm md:text-base">
          {homeContent.hotel.paragraph}
        </p>
        <a href={homeContent.hotel.ctaHref} class="btn">{homeContent.hotel.cta}</a>
      </div>
    </section>

    <section class="section section--soft">
      <div class="container-x">
        <SectionIntro
          titleText={homeContent.habitaciones.title}
          lead={homeContent.habitaciones.description}
        />
        <RoomGrid />
      </div>
    </section>

    <section class="bg-[#404040] px-6 py-20 text-center">
      <img
        src={images.eventoTitle}
        alt={homeContent.eventos.title}
        class="mx-auto mb-4 h-auto w-48 md:w-56"
        loading="lazy"
      />

      <h3 class="mb-10 font-display text-2xl font-normal text-white md:text-3xl">
        {homeContent.eventos.title}
      </h3>

      <EventsRows items={events} />

      <a
        href={homeContent.eventos.ctaHref}
        class="btn border-white/40 text-white hover:bg-white hover:text-[#404040] hover:border-white"
      >
        {homeContent.eventos.cta}
      </a>
    </section>

    <section class="section restaurant-feature">
      <div class="container-x">
        <div class="restaurant-feature__inner">
          <div class="restaurant-feature__carousel">
            {
              images.restSlides.map((src, index) => (
                <img
                  src={src}
                  alt={`El Veintidós Restaurante ${index + 1}`}
                  class:list={["restaurant-feature__slide", index === 0 && "is-active"]}
                  loading="lazy"
                />
              ))
            }
          </div>

          <img
            src={images.restLogo}
            alt="El Veintidós Restaurante"
            class="restaurant-feature__logo"
            loading="lazy"
          />

          <header class="restaurant-feature__header">
            <h3
              class="font-display text-2xl md:text-3xl font-normal tracking-tighter text-ink-dark mt-5 mb-2.5"
            >
              {homeContent.restaurante.title}
            </h3>
            <p>{homeContent.restaurante.description}</p>
          </header>

          <div class="restaurant-feature__row">
            {
              images.restSlides.map((src, index) => (
                <img
                  src={src}
                  alt={`El Veintidós Restaurante ${index + 1}`}
                  class="restaurant-feature__photo"
                  loading="lazy"
                />
              ))
            }
          </div>

          <a href={homeContent.restaurante.ctaHref} class="btn"> Ver Menú </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero__cta {
    bottom: 2rem;
    left: 50%;
  }

  .restaurant-feature__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
  }

  .restaurant-feature__carousel {
    position: relative;
    width: 100%;
    height: 14rem;
    overflow: hidden;
  }

  .restaurant-feature__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation: rest-fade 16s infinite;
  }

  .restaurant-feature__slide:nth-child(2) {
    animation-delay: 4s;
  }

  .restaurant-feature__slide:nth-child(3) {
    animation-delay: 8s;
  }

  .restaurant-feature__slide:nth-child(4) {
    animation-delay: 12s;
  }

  .restaurant-feature__logo {
    max-width: 13rem;
    height: auto;
  }
  .restaurant-feature__row {
    display: none;
  }

  @keyframes rest-fade {
    0% {
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    25% {
      opacity: 1;
    }
    30% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @media (min-width: 768px) {
    .restaurant-feature__carousel {
      display: none;
    }

    .restaurant-feature__row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      width: 100%;
      max-width: 72rem;
    }

    .restaurant-feature__photo {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
    }
  }
</style>
