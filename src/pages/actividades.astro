---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import { site } from "../data/site";

const activities = [
  {
    title: "HISTORIA Y TRADICIONES",
    subtitle: "De Xico, Pueblo Mágico",
    description:
      "Conoce más sobre la historia, fiestas, tradiciones y gastronomía de nuestro pueblo. Disfruta de un recorrido caminando acompañado de un guía certificado por el centro histórico.",
    duration: "2 hrs. Aprox.",
    image: "/assets/2017_07_slide_tradiciones_1.jpg",
  },
  {
    title: "COSECHA A LA TAZA",
    subtitle: "Experiencia del Café",
    description:
      "Una interesante visita a la plantación y proceso de beneficiado del café. Descubre el camino desde la semilla hasta tu taza en las fincas de altura que rodean Xico.",
    duration: "2 hrs. Aprox.",
    image: "/assets/2017_07_slide_cafeteria_1-1.jpg",
  },
  {
    title: "PASEO A CABALLO",
    subtitle: "Por el Campo y Cafetales",
    description:
      "Cabalga por el campo, fincas de café y observa las hermosas vistas que rodean el pueblo de Xico. Una experiencia única en contacto con la naturaleza.",
    duration: "2 hrs. Aprox.",
    image: "/assets/2016_09_actividades_fondo1.jpg",
  },
];

const galleryImages = [
  "/assets/2017_07_slide_tradiciones_2.jpg",
  "/assets/2017_07_slide_tradiciones_3.jpg",
  "/assets/2017_07_slide_cafeteria_2-1.jpg",
  "/assets/2017_07_slide_jardin_1.jpg",
  "/assets/2017_07_slide_jardin_2.jpg",
  "/assets/2017_07_slide_jardin_3.jpg",
];
---

<BaseLayout
  title={`Actividades y Experiencias en Xico, Veracruz | ${site.name}`}
  description="Actividades y experiencias en Xico, Pueblo Mágico de Veracruz: recorridos históricos, experiencia del café cosecha a la taza y paseos a caballo por cafetales."
  canonicalPath="/actividades/"
>
  <main>
    <PageHero title="ACTIVIDADES" image="/assets/2016_09_actividades_fondo.jpg" />
    <h1 class="sr-only">Actividades y Experiencias en Xico, Veracruz</h1>

    <section class="section">
      <div class="container-x">
        <SectionIntro
          lead="Xico es un Pueblo Mágico rodeado de naturaleza, tradición y gastronomía. Disfruta de actividades al aire libre, caminatas por el centro histórico, cafetales y experiencias gastronómicas que harán de tu visita un momento inolvidable."
        />
      </div>
    </section>

    <section class="section activities-feature">
      <div class="container-x">
        <div class="activities-feature__grid">
          {
            activities.map((activity, index) => (
              <article
                class={`activity-card activity-card--${index % 2 === 0 ? "normal" : "reverse"}`}
              >
                <div class="activity-card__image-wrapper">
                  <img
                    src={activity.image}
                    alt={activity.title}
                    class="activity-card__image"
                    loading="lazy"
                  />
                </div>
                <div class="activity-card__content">
                  <p class="activity-card__eyebrow">Experiencia {index + 1}</p>
                  <h2 class="font-display text-2xl md:text-3xl tracking-[0.1em] uppercase text-accent-dark text-center mb-2 mt-0">
                    {activity.title}
                  </h2>
                  <p class="activity-card__subtitle">{activity.subtitle}</p>
                  <p class="activity-card__description">{activity.description}</p>
                  <p class="activity-card__duration">
                    <span class="activity-card__duration-icon">⏱</span>
                    {activity.duration}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section activities-reservation">
      <div class="container-x">
        <div class="activities-reservation__inner">
          <p class="activities-reservation__note">
            Todas las actividades se pueden llevar a cabo bajo una previa reservación.
          </p>
          <a href="/contacto/" class="btn"> Solicitar Reservación </a>
          <p class="activities-reservation__contact">
            O contáctanos directamente:
            <a
              href={`tel:${site.phoneTel}`}
              class="text-accent hover:text-accent-dark transition-colors"
            >
              {site.phone}
            </a>
          </p>
        </div>
      </div>
    </section>

    <section class="section section--soft">
      <div class="container-x">
        <h2
          class="font-display text-2xl tracking-[0.12em] uppercase text-accent-dark text-center mb-8 mt-0"
        >
          Galería de Experiencias
        </h2>
        <div class="activities-gallery">
          {
            galleryImages.map((src, i) => (
              <figure class={`activities-gallery__item activities-gallery__item--${i + 1}`}>
                <img
                  src={src}
                  alt={`Experiencias en Xico, Veracruz - ${i + 1}`}
                  class="activities-gallery__image"
                  loading="lazy"
                />
              </figure>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .activities-feature {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 85% 8%, rgba(231, 173, 68, 0.14), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 50%, #f7f4f2 100%);
  }

  .activities-feature::before {
    content: "";
    position: absolute;
    inset: 2rem;
    pointer-events: none;
    border: 1px solid rgba(114, 48, 95, 0.12);
  }

  .activities-feature__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 3rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .activity-card {
    display: grid;
    gap: 1.5rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 1.5rem 3rem rgba(84, 63, 63, 0.1);
  }

  .activity-card__image-wrapper {
    position: relative;
    overflow: hidden;
    min-height: 16rem;
    background: #1d1d1d;
  }

  .activity-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .activity-card:hover .activity-card__image {
    transform: scale(1.04);
  }

  .activity-card__content {
    padding: 1.5rem 1.25rem;
  }

  .activity-card__eyebrow {
    margin: 0 0 0.75rem;
    color: #72305f;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  .activity-card__subtitle {
    margin: 0 0 1rem;
    color: #8a8a8a;
    font-size: 0.875rem;
    font-style: italic;
    text-align: center;
  }

  .activity-card__description {
    margin: 0 0 1.25rem;
    color: #4a4a4a;
    line-height: 1.7;
    text-align: center;
  }

  .activity-card__duration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    color: #72305f;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .activity-card__duration-icon {
    font-size: 1rem;
  }

  .activities-reservation {
    background: #f7f4f2;
  }

  .activities-reservation__inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    text-align: center;
    background: #fff;
    border: 1px solid rgba(231, 173, 68, 0.22);
    box-shadow: 0 1.5rem 3rem rgba(84, 63, 63, 0.08);
  }

  .activities-reservation__note {
    margin: 0 0 1.25rem;
    color: #4a4a4a;
    font-size: 1rem;
    line-height: 1.6;
  }

  .activities-reservation__contact {
    margin: 1.25rem 0 0;
    color: #8a8a8a;
    font-size: 0.875rem;
  }

  .activities-gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 10rem;
    gap: 0.75rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .activities-gallery__item {
    position: relative;
    overflow: hidden;
    margin: 0;
    background: #1d1d1d;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.12);
  }

  .activities-gallery__item--1,
  .activities-gallery__item--6 {
    grid-column: span 2;
    grid-row: span 2;
  }

  .activities-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .activities-gallery__item:hover .activities-gallery__image {
    transform: scale(1.04);
  }

  @media (min-width: 768px) {
    .activities-feature__grid {
      gap: 4rem;
    }

    .activity-card {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 0;
    }

    .activity-card--reverse .activity-card__image-wrapper {
      order: 2;
    }

    .activity-card--reverse .activity-card__content {
      order: 1;
    }

    .activity-card__image-wrapper {
      min-height: 20rem;
    }

    .activity-card__content {
      padding: 2.5rem 2rem;
    }

    .activities-gallery {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      grid-auto-rows: 12rem;
      gap: 1rem;
    }

    .activities-gallery__item--1 {
      grid-column: span 2;
      grid-row: span 2;
    }

    .activities-gallery__item--2,
    .activities-gallery__item--3 {
      grid-column: span 2;
    }

    .activities-gallery__item--4,
    .activities-gallery__item--5 {
      grid-column: span 2;
    }

    .activities-gallery__item--6 {
      grid-column: span 4;
      grid-row: span 1;
    }
  }

  @media (min-width: 1024px) {
    .activities-gallery {
      grid-auto-rows: 14rem;
    }

    .activities-gallery__item--6 {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
</style>
