---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSlider from "../components/HeroSlider.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import StickyTabs from "../components/StickyTabs.astro";
import { images, site, social } from "../data/site";
import { menuSections } from "../data/menu";

const restSlides = [
  "/assets/2017_07_slide_restaurante_1.jpg",
  "/assets/2017_07_slide_restaurante_2.jpg",
  "/assets/2017_07_slide_restaurante_4-1.jpg",
  "/assets/2017_07_slide_restaurante_3.jpg",
];

const platillos = [
  "/assets/2017_06_restaurante-1.jpg",
  "/assets/2017_06_restaurante-2.jpg",
  "/assets/2017_06_restaurante-3.jpg",
  "/assets/2017_06_restaurante-4.jpg",
];

const cafeteriaSlides = [
  "/assets/2017_07_slide_cafeteria_7.jpg",
  "/assets/2017_07_slide_cafeteria_12.jpg",
  "/assets/2017_08_slide_cafeteria_13.jpg",
  "/assets/2017_07_slide_cafeteria_10.jpg",
  "/assets/2017_07_slide_cafeteria_8.jpg",
  // "/assets/2017_07_slide_corredor_3.jpg",
];

const cafeteriaLogo = "/assets/2017_06_cafeteria_logo@2x-253x300.png";

const menuTabs = menuSections.map((s) => ({ id: s.id, label: s.label }));

const restaurantLd = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: "El Veintidós Restaurante & Cava",
  description:
    "Restaurante en Xico, Veracruz. Platillos prehispánicos, tradicionales de Xico y españoles. Desayunos, comida y cena en un Pueblo Mágico.",
  url: `${site.url}/restaurante/`,
  image: new URL(images.restSlides[0], site.url).toString(),
  telephone: site.phoneTel,
  servesCuisine: ["Prehispánica", "Tradicional de Xico", "Española"],
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hidalgo 123, Colonia Centro",
    addressLocality: "Xico",
    addressRegion: "Veracruz",
    postalCode: "91240",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  acceptsReservations: "True",
};
---

<BaseLayout
  title={`El Veintidós | Restaurante en Xico, Veracruz`}
  description="Restaurante en Xico, Veracruz: desayunos, comida y cena con platillos prehispánicos, tradicionales de Xico y españoles. Reserva en El Veintidós Restaurante & Cava, Pueblo Mágico."
  canonicalPath="/restaurante/"
  jsonLd={[restaurantLd]}
>
  <main>
    <h1 class="sr-only">El Veintidós - Restaurante en Xico, Veracruz</h1>
    <HeroSlider slides={restSlides} alt="El Veintidós Restaurante" height="60vh" />

    <section class="section bg-white">
      <div class="container-x">
        <img
          src={images.restLogo}
          alt="El Veintidós Restaurante"
          class="w-48 h-auto mx-auto mb-6"
          loading="lazy"
        />
        <SectionDivider />
        <SectionIntro
          titleText="“RESCATANDO SABORES DEL PUEBLO”"
          lead="Nuestro restaurante ofrece un menú que nace del sincretismo de la cultura indígena y española que se dio en Xico. En El Veintidós podrás encontrar platillos prehispánicos, tradicionales de Xico y españoles preparados con productos que se cosechan y se producen en el pueblo."
        />
        <div class="grid grid-cols-2 gap-4 max-w-4xl mx-auto my-12">
          {
            platillos.map((src, i) => (
              <img
                src={src}
                alt={`Platillo de El Veintidós Restaurante en Xico, Veracruz - ${i + 1}`}
                class="w-full aspect-[4/3] object-cover"
                loading="lazy"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section--soft" id="menu-section">
      <div class="container-x">
        <h2
          class="font-display text-3xl tracking-[0.12em] uppercase text-accent-dark text-center mb-2 mt-0"
        >
          Menú
        </h2>
        <SectionDivider />
      </div>

      <StickyTabs tabs={menuTabs} />

      <div class="container-x pt-12">
        {
          menuSections.map((section) => (
            <div id={section.id} data-tab-section class="mb-16 scroll-mt-24">
              <h3 class="font-display text-xl tracking-[0.1em] uppercase text-accent-dark text-center mb-8 mt-0">
                {section.label}
              </h3>
              {section.subsections.map((sub) => (
                <div class="mb-8">
                  {sub.title && (
                    <h4 class="font-display text-lg font-bold text-ink text-center mb-4 mt-0">
                      {sub.title}
                    </h4>
                  )}
                  <ul class="list-none p-0 m-0 max-w-2xl mx-auto">
                    {sub.items.map((item) => (
                      <li class="flex justify-between items-baseline gap-4 py-2 border-b border-line/50 last:border-0">
                        <div class="flex-1">
                          <span class="font-semibold text-ink">{item.name}</span>
                          {item.description && (
                            <span class="block text-ink-soft text-sm mt-0.5">
                              {item.description}
                            </span>
                          )}
                        </div>
                        <span class="font-semibold text-accent-dark whitespace-nowrap">
                          {item.price}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
              {section.note && <p class="text-ink-soft italic text-center mt-4">{section.note}</p>}
            </div>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="container-x text-center">
        <h2 class="font-display text-4xl tracking-[0.08em] text-ink mb-2 mt-0">Buen Provecho</h2>
        <p class="text-ink-soft mb-1">Reservaciones:</p>
        <a
          href={`tel:${site.phoneTel}`}
          class="font-display text-2xl text-accent hover:text-accent-dark transition-colors"
        >
          +52 (228) 8130314
        </a>
      </div>
    </section>

    <section class="section cafe-feature">
      <div class="container-x">
        <div class="cafe-feature__grid">
          <div class="cafe-feature__content">
            <div class="cafe-feature__logo-card">
              <img
                src={cafeteriaLogo}
                alt="Flor de Café - Cafetería & Pastelería"
                class="w-44 h-auto mx-auto"
                loading="lazy"
              />
            </div>
            <p class="font-display text-2xl text-ink italic text-center mb-8">
              Un café es siempre una buena idea.
            </p>
            <p class="max-w-3xl mx-auto mb-0 text-ink-soft text-center">
              Su ambiente acogedor y la belleza del lugar hacen de Flor de Café, un espacio ideal
              para disfrutar un buen café en compañía de tu pareja, amigos o familiares. Comparte tu
              momento con un delicioso postre o pastel elaborados en casa.
            </p>
          </div>

          <div class="cafe-feature__gallery">
            {
              cafeteriaSlides.map((src, i) => (
                <img
                  src={src}
                  alt={`Flor de Café, cafetería en Xico, Veracruz - ${i + 1}`}
                  class={`cafe-feature__image cafe-feature__image--${i + 1}`}
                  loading="lazy"
                />
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container-x">
        <h2
          class="font-display text-lg tracking-[0.14em] uppercase text-accent-dark text-center mb-4 mt-0"
        >
          SIGUENOS EN REDES
        </h2>
        <ul
          class="list-none p-0 m-0 flex justify-center gap-6 uppercase tracking-[0.12em] text-sm"
          aria-label="Redes del restaurante"
        >
          <li>
            <a
              href={social.restaurantFacebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              Facebook
            </a>
          </li>
          <li>
            <a
              href={social.restaurantInstagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              Instagram
            </a>
          </li>
          <li>
            <a
              href={social.restaurantTripadvisor}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              TripAdvisor
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .cafe-feature {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 12%, rgba(231, 173, 68, 0.18), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 100%);
  }

  .cafe-feature::before {
    content: "";
    position: absolute;
    inset: 2rem;
    pointer-events: none;
    border: 1px solid rgba(114, 48, 95, 0.14);
  }

  .cafe-feature__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 2.5rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .cafe-feature__content {
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 1.5rem 3rem rgba(84, 63, 63, 0.09);
  }

  .cafe-feature__logo-card {
    width: fit-content;
    margin: 0 auto 1.5rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(231, 173, 68, 0.28);
  }

  .cafe-feature__gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 10rem;
    gap: 0.75rem;
  }

  .cafe-feature__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.14);
  }

  .cafe-feature__image--1 {
    grid-row: span 2;
  }

  @media (min-width: 768px) {
    .cafe-feature__grid {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
    }

    .cafe-feature__content {
      padding: 3rem 2rem;
    }

    .cafe-feature__gallery {
      grid-auto-rows: 11rem;
    }
  }
</style>
