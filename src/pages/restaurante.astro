---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSlider from "../components/HeroSlider.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import StickyTabs from "../components/StickyTabs.astro";
import { images, site, social } from "../data/site";
import { menuSections } from "../data/menu";

const restSlides = [
  "/assets/2017_07_slide_restaurante_1.jpg",
  "/assets/2017_07_slide_restaurante_2.jpg",
  "/assets/2017_07_slide_restaurante_4-1.jpg",
  "/assets/2017_07_slide_restaurante_3.jpg",
];

const platillos = [
  "/assets/2017_06_restaurante-1.jpg",
  "/assets/2017_06_restaurante-2.jpg",
  "/assets/2017_06_restaurante-3.jpg",
  "/assets/2017_06_restaurante-4.jpg",
];

const cafeteriaSlides = [
  "/assets/2017_07_slide_cafeteria_7.jpg",
  "/assets/2017_07_slide_cafeteria_12.jpg",
  "/assets/2017_08_slide_cafeteria_13.jpg",
  "/assets/2017_07_slide_cafeteria_10.jpg",
  "/assets/2017_07_slide_cafeteria_8.jpg",
  "/assets/2017_07_slide_corredor_3.jpg",
];

const cafeteriaLogo = "/assets/2017_06_cafeteria_logo@2x-253x300.png";

const menuTabs = menuSections.map((s) => ({ id: s.id, label: s.label }));
---

<BaseLayout
  title={`El Veintidós - Restaurante & Cava - Xico, Pueblo Mágico de Veracruz`}
  description="El Veintidós: restaurante en Xico, Veracruz. Platillos prehispánicos, tradicionales y españoles."
  canonicalPath="/restaurante/"
>
  <main>
    <HeroSlider slides={restSlides} alt="El Veintidós Restaurante" height="70vh" />

    <section class="section">
      <div class="container-x">
        <img
          src={images.restLogo}
          alt="El Veintidós Restaurante"
          class="w-48 h-auto mx-auto mb-6"
          loading="lazy"
        />
        <SectionDivider />
        <SectionIntro
          titleText="“RESCATANDO SABORES DEL PUEBLO”"
          lead="Nuestro restaurante ofrece un menú que nace del sincretismo de la cultura indígena y española que se dio en Xico. En El Veintidós podrás encontrar platillos prehispánicos, tradicionales de Xico y españoles preparados con productos que se cosechan y se producen en el pueblo."
        />
        <div class="grid grid-cols-2 gap-4 max-w-4xl mx-auto mb-12">
          {
            platillos.map((src, i) => (
              <img
                src={src}
                alt={`Platillo ${i + 1}`}
                class="w-full aspect-[4/3] object-cover"
                loading="lazy"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section--soft" id="menu-section">
      <div class="container-x">
        <h2
          class="font-display text-3xl tracking-[0.12em] uppercase text-accent-dark text-center mb-2 mt-0"
        >
          Menú
        </h2>
        <SectionDivider />
      </div>

      <StickyTabs tabs={menuTabs} />

      <div class="container-x pt-12">
        {
          menuSections.map((section) => (
            <div id={section.id} data-tab-section class="mb-16 scroll-mt-24">
              <h3 class="font-display text-xl tracking-[0.1em] uppercase text-accent-dark text-center mb-8 mt-0">
                {section.label}
              </h3>
              {section.subsections.map((sub) => (
                <div class="mb-8">
                  {sub.title && (
                    <h4 class="font-display text-lg font-bold text-ink text-center mb-4 mt-0">
                      {sub.title}
                    </h4>
                  )}
                  <ul class="list-none p-0 m-0 max-w-2xl mx-auto">
                    {sub.items.map((item) => (
                      <li class="flex justify-between items-baseline gap-4 py-2 border-b border-line/50 last:border-0">
                        <div class="flex-1">
                          <span class="font-semibold text-ink">{item.name}</span>
                          {item.description && (
                            <span class="block text-ink-soft text-sm mt-0.5">
                              {item.description}
                            </span>
                          )}
                        </div>
                        <span class="font-semibold text-accent-dark whitespace-nowrap">
                          {item.price}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
              {section.note && (
                <p class="text-ink-soft text-sm italic text-center mt-4">{section.note}</p>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="container-x text-center">
        <h2 class="font-display text-4xl tracking-[0.08em] text-ink mb-2 mt-0">Buen Provecho</h2>
        <p class="text-ink-soft text-lg mb-1">Reservaciones:</p>
        <a
          href={`tel:${site.phoneTel}`}
          class="font-display text-2xl text-accent hover:text-accent-dark transition-colors"
        >
          +52 (228) 8130314
        </a>
      </div>
    </section>

    <section class="section section--soft">
      <div class="container-x">
        <img
          src={cafeteriaLogo}
          alt="Flor de Café - Cafetería & Pastelería"
          class="w-44 h-auto mx-auto mb-6"
          loading="lazy"
        />
        <p class="font-display text-xl text-ink-soft italic text-center mb-8">
          Un café es siempre una buena idea.
        </p>
        <p class="max-w-3xl mx-auto mb-8 text-ink-soft leading-[1.7] text-center">
          Su ambiente acogedor y la belleza del lugar hacen de Flor de Café, un espacio ideal para
          disfrutar un buen café en compañía de tu pareja, amigos o familiares. Comparte tu momento
          con un delicioso postre o pastel elaborados en casa.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 max-w-4xl mx-auto">
          {
            cafeteriaSlides.map((src, i) => (
              <img
                src={src}
                alt={`Cafetería ${i + 1}`}
                class="w-full aspect-[4/3] object-cover"
                loading="lazy"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container-x">
        <h2
          class="font-display text-lg tracking-[0.14em] uppercase text-accent-dark text-center mb-4 mt-0"
        >
          SIGUENOS EN REDES
        </h2>
        <ul
          class="list-none p-0 m-0 flex justify-center gap-6 uppercase tracking-[0.12em] text-sm"
          aria-label="Redes del restaurante"
        >
          <li>
            <a
              href={social.restaurantFacebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              Facebook
            </a>
          </li>
          <li>
            <a
              href={social.restaurantInstagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              Instagram
            </a>
          </li>
          <li>
            <a
              href={social.restaurantTripadvisor}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-dark transition-colors"
            >
              TripAdvisor
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
