---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSlider from "../components/HeroSlider.astro";
import RestaurantMenu from "../components/RestaurantMenu.astro";
import SectionCafeteria from "../components/SectionCafeteria.astro";
import SectionRestaurante from "../components/SectionRestaurante.astro";
import { images, site, social } from "../data/site";

const restSlides = [
  "/assets/2017_07_slide_restaurante_1.jpg",
  "/assets/2017_07_slide_restaurante_2.jpg",
  "/assets/2017_07_slide_restaurante_4-1.jpg",
  "/assets/2017_07_slide_restaurante_3.jpg",
];

const platillos = [
  "/assets/2017_06_restaurante-1.jpg",
  "/assets/2017_06_restaurante-2.jpg",
  "/assets/2017_06_restaurante-3.jpg",
  "/assets/2017_06_restaurante-4.jpg",
];

const restaurantLd = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: "El Veintidós Restaurante & Cava",
  description:
    "Restaurante en Xico, Veracruz. Platillos prehispánicos, tradicionales de Xico y españoles. Desayunos, comida y cena en un Pueblo Mágico.",
  url: `${site.url}/restaurante/`,
  image: new URL(images.restSlides[0], site.url).toString(),
  telephone: site.phoneTel,
  servesCuisine: ["Prehispánica", "Tradicional de Xico", "Española"],
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hidalgo 123, Colonia Centro",
    addressLocality: "Xico",
    addressRegion: "Veracruz",
    postalCode: "91240",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  acceptsReservations: "True",
};
---

<BaseLayout
  title={`El Veintidós | Restaurante en Xico, Veracruz`}
  description="Restaurante en Xico, Veracruz: desayunos, comida y cena con platillos prehispánicos, tradicionales de Xico y españoles. Reserva en El Veintidós Restaurante & Cava, Pueblo Mágico."
  canonicalPath="/restaurante/"
  jsonLd={[restaurantLd]}
>
  <main>
    <h1 class="sr-only">El Veintidós - Restaurante en Xico, Veracruz</h1>
    <HeroSlider slides={restSlides} alt="El Veintidós Restaurante" height="60vh" />

    <SectionRestaurante
      logo={images.restLogo}
      title={"RESCATANDO SABORES DEL PUEBLO"}
      description="Nuestro restaurante ofrece un menú que nace del sincretismo de la cultura indígena y española que se dio en Xico. En El Veintidós podrás encontrar platillos prehispánicos, tradicionales de Xico y españoles preparados con productos que se cosechan y se producen en el pueblo."
      images={platillos}
    />

    <RestaurantMenu />

    <section class="section">
      <div class="container-x text-center">
        <h2 class="font-display text-4xl tracking-[0.08em] text-ink mb-2 mt-0">Buen Provecho</h2>
        <p class="text-ink-soft mb-1">Reservaciones:</p>
        <a
          href={`tel:${site.phoneTel}`}
          class="font-display text-2xl text-ink hover:text-accent-dark transition-colors"
        >
          +52 (228) 8130314
        </a>

        <h3
          class="font-display text-lg tracking-[0.14em] uppercase text-ink text-center mb-4 mt-10"
        >
          SIGUENOS EN REDES
        </h3>
        <ul
          class="list-none flex gap-3.5 justify-center p-0"
          aria-label="Redes del restaurante"
        >
          <li>
            <a
              href={social.restaurantFacebook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              class="inline-flex items-center justify-center w-9 h-9 border border-line text-ink-soft hover:text-accent hover:border-accent transition-colors"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07c0 5 3.66 9.13 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22c4.78-.8 8.43-4.93 8.43-9.93Z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={social.restaurantInstagram}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="inline-flex items-center justify-center w-9 h-9 border border-line text-ink-soft hover:text-accent hover:border-accent transition-colors"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.74 3.74 0 0 1-1.38-.9 3.74 3.74 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 2.16c-3.14 0-3.51.01-4.74.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.27.83-.39.39-.63.76-.83 1.27-.15.39-.33.97-.38 2.04-.06 1.23-.07 1.6-.07 4.74s.01 3.51.07 4.74c.05 1.07.23 1.65.38 2.04.2.51.44.88.83 1.27.39.39.76.63 1.27.83.39.15.97.33 2.04.38 1.23.06 1.6.07 4.74.07s3.51-.01 4.74-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.27-.83.39-.39.63-.76.83-1.27.15-.39.33-.97.38-2.04.06-1.23.07-1.6.07-4.74s-.01-3.51-.07-4.74c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.83-1.27 3.4 3.4 0 0 0-1.27-.83c-.39-.15-.97-.33-2.04-.38C15.51 4.33 15.14 4.32 12 4.32Zm0 3.68a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm0 6.6a2.6 2.6 0 1 0 0-5.2 2.6 2.6 0 0 0 0 5.2Zm5.1-6.76a.96.96 0 1 1-1.92 0 .96.96 0 0 1 1.92 0Z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={social.restaurantTripadvisor}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TripAdvisor"
              class="inline-flex items-center justify-center w-9 h-9 border border-line text-ink-soft hover:text-accent hover:border-accent transition-colors"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M19.5 7.5h-15A1.5 1.5 0 0 0 3 9v6a1.5 1.5 0 0 0 1.5 1.5h.74a4 4 0 0 0 7.52 0h1.48a4 4 0 0 0 7.52 0h.24A1.5 1.5 0 0 0 21 15V9a1.5 1.5 0 0 0-1.5-1.5Zm-14 8.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Zm9 0a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <SectionCafeteria />
  </main>
</BaseLayout>
