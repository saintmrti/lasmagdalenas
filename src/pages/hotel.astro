---
import HeroSlider from "../components/HeroSlider.astro";
import RoomGrid from "../components/RoomGrid.astro";
import SectionDivider from "../components/SectionDivider.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { images, site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const hotelSlides = [
  "/assets/2017_07_slide_hotel_1-1.jpg",
  "/assets/2017_07_slide_hotel_2-1.jpg",
  "/assets/2017_07_slide_hotel_4.jpg",
];

const hotelGallery = [
  // "/assets/2017_07_slide_hotel_1-1.jpg",
  "/assets/2017_07_slide_hotel_2-1.jpg",
  "/assets/2017_07_slide_hotel_3-1.jpg",
  "/assets/2017_07_slide_hotel_4.jpg",
  // "/assets/2017_07_slide_hotel_9.jpg",
  "/assets/2017_07_slide_hotel_10.jpg",
];

const servicios = [
  { icon: "🍽", text: "Restaurante de especialidad" },
  { icon: "🍷", text: "Cava & Bar" },
  { icon: "☕", text: "Cafetería" },
  { icon: "📶", text: "Internet Wi-Fi de alta velocidad" },
  { icon: "🅿️", text: "Estacionamiento privado" },
  { icon: "🛎", text: "Servicio en habitaciones" },
  { icon: "✨", text: "Decoración de habitaciones*" },
  { icon: "✈️", text: "Traslado al aeropuerto*" },
  { icon: "🚌", text: "Traslado a central de autobuses de Xalapa*" },
];

const hotelLd = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  name: site.name,
  description:
    "Hotel boutique en Xico, Veracruz, ubicado en una casona colonial del siglo XIX. Hospedaje con habitaciones, restaurante y eventos en un Pueblo Mágico.",
  url: `${site.url}/hotel/`,
  image: new URL(images.habitacionDeluxe, site.url).toString(),
  telephone: site.phoneTel,
  email: site.email,
  priceRange: "$$",
  starRating: { "@type": "Rating", ratingValue: "4" },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hidalgo 123, Colonia Centro",
    addressLocality: "Xico",
    addressRegion: "Veracruz",
    postalCode: "91240",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  amenityFeature: [
    { "@type": "LocationFeatureSpecification", name: "Restaurante" },
    { "@type": "LocationFeatureSpecification", name: "Cava & Bar" },
    { "@type": "LocationFeatureSpecification", name: "Cafetería" },
    { "@type": "LocationFeatureSpecification", name: "Wi-Fi" },
    { "@type": "LocationFeatureSpecification", name: "Estacionamiento" },
  ],
};
---

<BaseLayout
  title={`Hotel Boutique en Xico, Veracruz | ${site.name}`}
  description="Hotel boutique en Xico, Veracruz: hospedaje en una casona colonial del siglo XIX. Habitaciones con vigones de madera, restaurante, cafetería y servicios. Hoteles y hospedaje en Xico, Pueblo Mágico."
  canonicalPath="/hotel/"
  jsonLd={[hotelLd]}
>
  <main>
    <h1 class="sr-only">Hotel Boutique en Xico, Veracruz</h1>
    <HeroSlider slides={hotelSlides} alt="Hotel Las Magdalenas" height="70vh" />

    <section class="section">
      <div class="container-x">
        <SectionDivider />
        <SectionIntro
          titleImage={images.hotelTitle}
          titleText="Magnífica casona estilo colonial construida en el siglo XIX"
          lead="Las Magdalenas Hotel Boutique emerge en una magnífica casona estilo colonial construida en el Siglo XIX, considerada ya, un monumento histórico. La exquisitez de su ambiente, es ideal para los huéspedes que desean una estancia llena de historia, descanso y servicio personalizado."
        />
        <p class="max-w-3xl mx-auto text-ink-soft leading-[1.7] text-center">
          Estamos ubicados en el Centro Histórico de Xico, Veracruz. Lo que permite a nuestros
          huéspedes caminar y disfrutar de los sitios culturales, naturales y gastronómicos más
          importantes de nuestro Pueblo Mágico.
        </p>
      </div>
    </section>

    <section class="section hotel-services">
      <div class="container-x">
        <p class="hotel-services__eyebrow">Todo incluido</p>
        <h2
          class="font-display text-3xl md:text-4xl leading-tight font-normal tracking-tighter text-ink-dark text-center mb-3 mt-0"
        >
          Servicios
        </h2>
        <SectionDivider />
        <div class="hotel-services__grid">
          {
            servicios.map((servicio) => (
              <div class="hotel-services__item">
                <span class="hotel-services__icon">{servicio.icon}</span>
                <span class="hotel-services__text">{servicio.text}</span>
              </div>
            ))
          }
        </div>
        <p class="hotel-services__note">*Servicios con cargo extra.</p>
      </div>
    </section>

    <section class="section">
      <div class="container-x">
        <SectionDivider />
        <SectionIntro
          titleText="HABITACIONES"
          lead="Nuestras acogedoras habitaciones cuentan con techos sostenidos por vigones de madera, muros de piedra y detalles contemporáneos que les dan calidez y confort."
        />
        <RoomGrid />
      </div>
    </section>

    <section id="galeria-hotel" class="mb-10">
      <div class="container-x">
        <div class="hotel-gallery__header">
          <p class="hotel-gallery__eyebrow">Las Magdalenas</p>
          <h2
            class="font-display text-3xl md:text-4xl leading-tight font-normal tracking-tighter text-ink-dark text-center mb-3 mt-0"
          >
            Galería del Hotel
          </h2>
          <SectionDivider />
          <p class="max-w-3xl mx-auto text-ink-soft leading-[1.7] text-center">
            Rincones coloniales, detalles de época y habitaciones pensadas para descansar bajo el
            encanto de Xico.
          </p>
        </div>

        <div class="hotel-gallery__grid">
          {
            hotelGallery.map((src, index) => (
              <figure class={`hotel-gallery__item hotel-gallery__item--${index + 1}`}>
                <img
                  src={src}
                  alt={`Hotel Las Magdalenas ${index + 1}`}
                  class="hotel-gallery__image"
                  loading="lazy"
                />
              </figure>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hotel-services {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 85% 10%, rgba(114, 48, 95, 0.08), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 40%, #f7f4f2 100%);
  }

  .hotel-services__eyebrow {
    margin: 0 0 0.75rem;
    color: #c04a40;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  .hotel-services__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    max-width: 48rem;
    margin: 0 auto;
  }

  .hotel-services__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(226, 220, 210, 0.5);
  }

  .hotel-services__item:nth-child(odd) {
    border-right: 1px solid rgba(226, 220, 210, 0.5);
  }

  .hotel-services__icon {
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .hotel-services__text {
    color: #4a4a4a;
    font-size: 0.875rem;
    line-height: 1.4;
    text-align: left;
  }

  .hotel-services__note {
    margin: 1.25rem 0 0;
    color: #8a8a8a;
    font-size: 0.75rem;
    font-style: italic;
    text-align: center;
  }

  /* .hotel-gallery {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 15% 10%, rgba(231, 173, 68, 0.18), transparent 28rem),
      linear-gradient(180deg, #f7f4f2 0%, #fff 100%);
  } */

  .hotel-gallery::before {
    content: "";
    position: absolute;
    inset: 2rem;
    pointer-events: none;
    border: 1px solid rgba(114, 48, 95, 0.12);
  }

  .hotel-gallery__header,
  .hotel-gallery__grid {
    position: relative;
    z-index: 1;
  }

  .hotel-gallery__header {
    max-width: 48rem;
    margin: 0 auto 2rem;
  }

  .hotel-gallery__eyebrow {
    margin: 0 0 0.75rem;
    color: #c04a40;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  .hotel-gallery__grid {
    column-count: 1;
    column-gap: 0.9rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .hotel-gallery__item {
    position: relative;
    overflow: hidden;
    break-inside: avoid;
    margin: 0 0 0.9rem;
    background: #1d1d1d;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.12);
  }

  .hotel-gallery__item--1 {
    grid-column: auto;
    grid-row: auto;
  }

  .hotel-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .hotel-gallery__item:hover .hotel-gallery__image {
    transform: scale(1.04);
  }

  .hotel-cta {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    text-align: center;
    background: linear-gradient(rgba(29, 29, 29, 0.44), rgba(29, 29, 29, 0.44)), #c04a40;
    box-shadow: 0 2rem 4rem rgba(29, 29, 29, 0.24);
  }

  .hotel-cta::before {
    content: "";
    position: absolute;
    inset: 1rem;
    pointer-events: none;
    border: 1px solid rgba(231, 173, 68, 0.36);
  }

  .hotel-cta__lead {
    position: relative;
    z-index: 1;
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
  }

  .hotel-cta__contact {
    position: relative;
    z-index: 1;
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .hotel-services__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hotel-services__item {
      border-right: 1px solid rgba(226, 220, 210, 0.5);
    }

    .hotel-services__item:nth-child(3n) {
      border-right: 0;
    }

    .hotel-gallery__header {
      margin-bottom: 2.5rem;
    }

    .hotel-gallery__grid {
      column-count: 2;
      column-gap: 1rem;
    }

    .hotel-cta {
      padding: 4rem 3rem;
    }
  }
</style>
