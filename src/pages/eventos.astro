---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import StickyTabs from "../components/StickyTabs.astro";
import { images, site } from "../data/site";
import { eventSpaces } from "../data/eventSpaces";

const eventTabs = eventSpaces.map((s) => ({ id: s.id, label: s.title }));
---

<BaseLayout
  title={`Eventos - ${site.name}`}
  description="Celebra tu evento en Las Magdalenas Hotel Boutique, Xico, Veracruz."
  canonicalPath="/eventos/"
>
  <main>
    <PageHero image={images.eventoHome} height="70vh" />

    <section class="section events-intro">
      <div class="container-x">
        <div class="events-intro__card">
          <img
            src={images.eventoTitle}
            alt="Eventos"
            class="max-w-60 mx-auto mb-6"
            loading="lazy"
          />
          <SectionDivider />
          <SectionIntro
            lead="Somos el marco perfecto para celebrar tu momento. Haz de tu evento una experiencia llena de historia, elegancia y exclusividad bajo el encanto de Las Magdalenas."
          />
        </div>
      </div>
    </section>

    <StickyTabs tabs={eventTabs} />

    <section class="section">
      <div class="container-x">
        {
          eventSpaces.map((space, index) => (
            <div
              id={space.id}
              data-tab-section
              class={`event-space event-space--${index % 2 === 0 ? "normal" : "reverse"} ${space.unavailable ? "event-space--unavailable" : ""}`}
            >
              <div class="event-space__content">
                <p class="event-space__eyebrow">Espacio {index + 1}</p>
                <h2 class="font-display text-3xl uppercase text-accent-dark text-center mb-6 mt-0">
                  {space.title}
                </h2>
                <p class="max-w-3xl mx-auto mb-4 text-ink-soft leading-[1.7] text-center">
                  {space.description}
                </p>

                {space.capacity && <p class="event-space__capacity">{space.capacity}</p>}

                {!space.unavailable && space.ctaLabel && space.ctaHref && (
                  <a href={space.ctaHref} class="btn">
                    {space.ctaLabel}
                  </a>
                )}
              </div>

              {space.images.length > 0 && (
                <div class="event-space__gallery">
                  {space.images.map((src, i) => (
                    <img
                      src={src}
                      alt={`${space.title} ${i + 1}`}
                      class={`event-space__image event-space__image--${i + 1}`}
                      loading="lazy"
                    />
                  ))}
                </div>
              )}
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .events-intro {
    margin-top: -4rem;
    background: linear-gradient(180deg, transparent 0%, #fff 4rem, #fff 100%);
  }

  .events-intro__card {
    position: relative;
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    background: linear-gradient(rgba(29, 29, 29, 0.44), rgba(29, 29, 29, 0.44)), #404040;
    box-shadow: 0 2rem 4rem rgba(29, 29, 29, 0.18);
  }

  .events-intro__card::before {
    content: "";
    position: absolute;
    inset: 1rem;
    pointer-events: none;
    border: 1px solid white;
  }

  .events-intro__card :global(p) {
    color: rgba(255, 255, 255, 0.82);
  }

  .event-space {
    display: grid;
    gap: 2rem;
    max-width: 68rem;
    margin: 0 auto 5rem;
    scroll-margin-top: 6rem;
  }

  .event-space:last-child {
    margin-bottom: 0;
  }

  .event-space__content {
    position: relative;
    padding: 2rem 1.5rem;
    background: #f7f4f2;
    border: 1px solid rgba(231, 173, 68, 0.22);
  }

  .event-space__eyebrow {
    margin: 0 0 0.75rem;
    color: #404040;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-align: center;
    text-transform: uppercase;
  }

  .event-space__capacity {
    margin: 0 0 1.5rem;
    color: #4a4a4a;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-align: center;
    text-transform: uppercase;
  }

  .event-space__gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .event-space__image {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    min-height: 10rem;
    object-fit: cover;
    box-shadow: 0 1.25rem 2.5rem rgba(84, 63, 63, 0.12);
  }

  .event-space__image--1 {
    grid-row: span 2;
  }

  .event-space--unavailable {
    max-width: 42rem;
  }

  .event-space--unavailable .event-space__content {
    background: #1d1d1d;
  }

  .event-space--unavailable :global(h2),
  .event-space--unavailable :global(p) {
    color: rgba(255, 255, 255, 0.82);
  }

  @media (min-width: 768px) {
    .events-intro__card {
      padding: 4rem 3rem;
    }

    .event-space {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
      margin-bottom: 6rem;
    }

    .event-space--reverse .event-space__content {
      order: 2;
    }

    .event-space--reverse .event-space__gallery {
      order: 1;
    }

    .event-space__content {
      padding: 3rem 2rem;
    }

    .event-space__image {
      min-height: 13rem;
    }

    .event-space--unavailable {
      display: block;
    }
  }
</style>
