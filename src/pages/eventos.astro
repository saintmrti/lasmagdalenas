---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SectionDivider from "../components/SectionDivider.astro";
import StickyTabs from "../components/StickyTabs.astro";
import { images, site } from "../data/site";
import { eventSpaces } from "../data/eventSpaces";

const eventTabs = eventSpaces.map((s) => ({ id: s.id, label: s.title }));
---

<BaseLayout
  title={`Eventos - ${site.name}`}
  description="Celebra tu evento en Las Magdalenas Hotel Boutique, Xico, Veracruz."
  canonicalPath="/eventos/"
>
  <main>
    <PageHero image={images.eventoHome} height="70vh" />

    <section class="section events-intro">
      <div class="container-x">
        <div class="events-intro__card">
          <img
            src={images.eventoTitle}
            alt="Eventos"
            class="max-w-60 mx-auto mb-6"
            loading="lazy"
          />
          <SectionDivider />
          <SectionIntro
            lead="Somos el marco perfecto para celebrar tu momento. Haz de tu evento una experiencia llena de historia, elegancia y exclusividad bajo el encanto de Las Magdalenas."
          />
        </div>
      </div>
    </section>

    <StickyTabs tabs={eventTabs} />

    <section class="section pt-7">
      <div class="container-x">
        {
          eventSpaces.map((space, index) => (
            <div id={space.id} data-tab-section class="mb-16 scroll-mt-24 last:mb-0">
              <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
                <div class="border border-[#e7ad44]/25 bg-surface-soft px-6 py-8 text-center md:px-8 md:py-12">
                  <p class="mb-3 mt-0 text-xs font-semibold uppercase tracking-[0.18em] text-[#404040]">
                    Espacio {index + 1}
                  </p>
                  <h2 class="font-display text-3xl uppercase text-accent-dark text-center mb-6 mt-0">
                    {space.title}
                  </h2>
                  <p class="mx-auto mb-4 max-w-3xl text-center leading-[1.7] text-ink-soft">
                    {space.description}
                  </p>

                  {space.capacity && (
                    <p class="mb-6 mt-0 text-center text-sm font-bold uppercase tracking-[0.14em] text-[#4a4a4a]">
                      {space.capacity}
                    </p>
                  )}

                  {space.ctaLabel && space.ctaHref && (
                    <a href={space.ctaHref} class="btn">
                      {space.ctaLabel}
                    </a>
                  )}
                </div>

                {space.images.length > 0 && (
                  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                    {space.images.map((src, imageIndex) => (
                      <img
                        src={src}
                        alt={`${space.title} ${imageIndex + 1}`}
                        class="aspect-4/3 min-h-40 w-full object-cover shadow-[0_1.25rem_2.5rem_rgba(84,63,63,0.12)]"
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .events-intro {
    margin-top: -4rem;
    background: linear-gradient(180deg, transparent 0%, #fff 4rem, #fff 100%);
  }

  .events-intro__card {
    position: relative;
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    background: linear-gradient(rgba(29, 29, 29, 0.44), rgba(29, 29, 29, 0.44)), #404040;
    box-shadow: 0 2rem 4rem rgba(29, 29, 29, 0.18);
  }

  .events-intro__card::before {
    content: "";
    position: absolute;
    inset: 1rem;
    pointer-events: none;
    border: 1px solid white;
  }

  .events-intro__card :global(p) {
    color: rgba(255, 255, 255, 0.82);
  }

  @media (min-width: 768px) {
    .events-intro__card {
      padding: 4rem 3rem;
    }
  }
</style>
