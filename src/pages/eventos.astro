---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionDivider from "../components/SectionDivider.astro";
import { images, site } from "../data/site";
import { eventSpaces } from "../data/eventSpaces";

const baseUrl = site.url;

const eventVenueLd = {
  "@context": "https://schema.org",
  "@type": "EventVenue",
  name: `${site.name} - Bodas y Eventos`,
  description:
    "Bodas y eventos en Xico, Veracruz. Celebra tu boda, reunión o ocasión especial en una casona colonial del siglo XIX.",
  url: `${baseUrl}/eventos/`,
  image: `${baseUrl}${images.eventoHome}`,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hidalgo 123, Colonia Centro",
    addressLocality: "Xico",
    addressRegion: "Veracruz",
    postalCode: "91240",
    addressCountry: "MX",
  },
  containsPlace: eventSpaces.map((space) => ({
    "@type": "Place",
    name: space.title,
    description: space.description,
    maximumAttendeeCapacity: space.capacity
      ? parseInt(space.capacity.replace(/\D/g, ""), 10) || undefined
      : undefined,
  })),
};
---

<BaseLayout
  title={`Bodas y Eventos en Xico, Veracruz | ${site.name}`}
  description="Bodas y eventos en Xico, Veracruz. Celebra tu boda, reunión o ocasión especial en una casona colonial del siglo XIX. Espacios únicos en Las Magdalenas Hotel Boutique, Pueblo Mágico."
  canonicalPath="/eventos/"
  jsonLd={[eventVenueLd]}
>
  <main class="bg-[#2b2b2b]">
    <h1 class="sr-only">Bodas y Eventos en Xico, Veracruz</h1>
    <PageHero image={images.eventoHome} height="60vh" />

    <section class="px-6 py-20 text-center">
      <img
        src={images.eventoTitle}
        alt="Eventos"
        class="mx-auto mb-4 h-auto w-48 md:w-56"
        loading="lazy"
      />
      <SectionDivider />

      <p class="mx-auto max-w-3xl text-center text-white/75 mb-16">
        Celebra tu boda, reunión o ocasión especial en una casona colonial del siglo XIX. Espacios
        únicos en Las Magdalenas Hotel Boutique, Pueblo Mágico.
      </p>

      <div class="container-x">
        {
          eventSpaces.map((space, index) => (
            <div id={space.id} data-tab-section class="mb-16 scroll-mt-24 last:mb-0">
              <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
                <div class="border border-white/25 bg-[#4d4d4d] px-6 py-8 text-center md:px-8 md:py-12">
                  <p class="mb-3 mt-0 text-xs font-semibold uppercase tracking-[0.18em] text-white/60">
                    Espacio {index + 1}
                  </p>
                  <h2 class="font-display text-3xl uppercase text-white text-center mb-6 mt-0">
                    {space.title}
                  </h2>
                  <p class="mx-auto mb-4 max-w-3xl text-center text-white/75">
                    {space.description}
                  </p>

                  {space.capacity && (
                    <p class="mb-6 mt-0 text-center text-sm font-bold uppercase tracking-[0.14em] text-white/80">
                      {space.capacity}
                    </p>
                  )}

                  {space.ctaLabel && space.ctaHref && (
                    <a href={space.ctaHref} class="btn text-white">
                      {space.ctaLabel}
                    </a>
                  )}
                </div>

                {space.images.length > 0 && (
                  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                    {space.images.map((src, imageIndex) => (
                      <img
                        src={src}
                        alt={`${space.title} ${imageIndex + 1}`}
                        class="aspect-4/3 min-h-40 w-full object-cover shadow-[0_1.25rem_2.5rem_rgba(0,0,0,0.3)]"
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
