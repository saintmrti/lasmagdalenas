---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";

const galleryImages = [
  "/assets/2016_09_habitaciones_home_20.jpg",
  "/assets/2016_09_habitaciones_home_21.jpg",
  "/assets/2016_09_habitaciones_home_22.jpg",
  "/assets/2016_09_habitaciones_home_23.jpg",
  "/assets/2016_09_habitaciones_home_24.jpg",
  "/assets/2016_09_habitaciones_home_26.jpg",
  "/assets/2016_09_rest_home_7.jpg",
  "/assets/2016_09_rest_home_3.jpg",
  "/assets/2016_09_rest_home_6.jpg",
  "/assets/2016_09_rest_home_4.jpg",
  "/assets/2016_09_eventoshome.jpg",
  "/assets/2016_09_promociones-1.jpg",
  "/assets/2017_07_slide_corredor_1.jpg",
  "/assets/2017_07_slide_corredor_2.jpg",
  "/assets/2017_07_slide_corredor_3.jpg",
  "/assets/2017_07_slide_jardin_1.jpg",
  "/assets/2017_07_slide_jardin_2.jpg",
  "/assets/2017_07_slide_patio_1.jpg",
  "/assets/2017_07_slide_patio_2.jpg",
  "/assets/2017_07_slide_hotel_1-1.jpg",
  "/assets/2017_07_slide_hotel_2-1.jpg",
  "/assets/2017_07_slide_hotel_3-1.jpg",
  "/assets/2017_07_slide_tradiciones_1.jpg",
  "/assets/2017_07_slide_tradiciones_2.jpg",
  "/assets/2017_07_slide_cafeteria_1-1.jpg",
  "/assets/2017_07_slide_cafeteria_2-1.jpg",
  "/assets/2017_07_slide_restaurante_3.jpg",
  "/assets/2017_07_slide_restaurante_4-1.jpg",
  "/assets/2017_07_slide_restaurante_10.jpg",
  "/assets/2017_07_slide_restaurante_11.jpg",
  "/assets/2017_07_slidehome_19.jpg",
  "/assets/2017_07_slidehome_20.jpg",
  "/assets/2017_07_slidehome_21.jpg",
  "/assets/2016_09_jardin_fondo.jpg",
  "/assets/2016_09_cafeteria_fondo.jpg",
  "/assets/2016_09_hotel-slider-1-870x500.jpg",
];
---

<BaseLayout
  title={`Galería - ${site.name}`}
  description="Galería de imágenes de Las Magdalenas Hotel Boutique."
  canonicalPath="/galeria/"
>
  <main>
    <PageHero title="GALERÍA" image={galleryImages[0]} />

    <section class="section">
      <div class="container-x">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 md:gap-3 lg:gap-4">
          {
            galleryImages.map((src) => (
              <img
                src={src}
                alt="Galería"
                class="w-full aspect-square object-cover"
                loading="lazy"
              />
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
