---
interface Props {
  images: string[];
  altPrefix?: string;
}

const { images, altPrefix = "" } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-[1100px] mx-auto mb-10">
  {
    images.map((src, i) => (
      <img
        src={src}
        alt={`${altPrefix} ${i + 1}`}
        class="w-full aspect-square object-cover"
        loading="lazy"
      />
    ))
  }
</div>
