---
import { promotions, images } from "../data/site";
---

<section class="mx-auto max-w-6xl">
  <ul class="list-none m-0 p-0 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
    {
      promotions.map((promo) => (
        <li class="text-center">
          <img
            src={promo.image}
            alt={promo.title}
            class="w-full aspect-[3/2] object-cover mb-4"
            loading="lazy"
          />
          <img
            src={images.habitacionesBullets}
            alt=""
            class="block w-[180px] h-auto mx-auto mb-3"
            loading="lazy"
          />
          <h3 class="font-display text-lg tracking-[0.14em] uppercase text-accent-dark mb-3 mt-0">
            {promo.title}
          </h3>
          <p class="text-ink-soft max-w-lg mx-auto mb-2 leading-relaxed">{promo.text}</p>
          {promo.extra && (
            <p class="text-ink-soft max-w-lg mx-auto mb-2 leading-relaxed">{promo.extra}</p>
          )}
        </li>
      ))
    }
  </ul>
</section>
