---
import { rooms } from "../data/site";
import { site } from "../data/site";
---

<section class="mx-auto max-w-6xl">
  <ul class="list-none my-10 p-0 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
    {
      rooms.map((room) => (
        <li class="bg-surface border border-line shadow-sm overflow-hidden text-center">
          <img
            src={room.image}
            alt={room.name}
            class="w-full aspect-4/3 object-cover"
            loading="lazy"
          />
          <div class="px-6 py-7">
            <h3 class="font-display text-xl tracking-[0.14em] uppercase text-accent-dark mb-2 mt-0">
              {room.name}
            </h3>
            <p class="text-ink-soft text-base m-0">{room.description}</p>
          </div>
        </li>
      ))
    }
  </ul>
  <a
    href={site.bookingUrl}
    class="btn text-center block md:inline-block"
    target="_blank"
    rel="noopener noreferrer"
  >
    VER DETALLES Y RESERVAR
  </a>
</section>
