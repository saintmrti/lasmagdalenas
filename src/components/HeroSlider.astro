---
interface Props {
  slides: string[];
  alt?: string;
  height?: string;
  decorated?: boolean;
}

const { slides, alt = "", height = "100vh", decorated = false } = Astro.props;
---

<section class="hero-slider" data-hero-slider style={`--hero-height:${height};`}>
  <div class="hero-slider__track" data-hero-track style={`transform: translateX(0%)`}>
    {
      slides.map((src, index) => (
        <div
          class="hero-slider__slide"
          style={`background-image:url(${src})`}
          role={index === 0 ? "img" : undefined}
          aria-label={index === 0 ? alt : undefined}
          aria-hidden={index === 0 ? undefined : "true"}
        />
      ))
    }
  </div>

  <div class="hero-slider__overlay" aria-hidden="true"></div>

  <div class="hero-slider__content">
    {
      decorated ? (
        <div class="hero-slider__decorated">
          <span class="hero-slider__line" />
          <slot />
          <span class="hero-slider__line" />
        </div>
      ) : (
        <slot />
      )
    }
  </div>

  <div class="hero-slider__dots" data-hero-dots aria-hidden="true">
    {
      slides.map((_, i) => (
        <button
          type="button"
          class:list={["hero-slider__dot", i === 0 && "is-active"]}
          data-hero-dot={i}
          aria-label={`Ir a la imagen ${i + 1}`}
        />
      ))
    }
  </div>
</section>

<script>
  const SWIPE_THRESHOLD = 50;
  const VELOCITY_THRESHOLD = 0.5;
  const AUTOPLAY_INTERVAL = 5000;

  const slider = document.querySelector<HTMLElement>("[data-hero-slider]");
  const track = document.querySelector<HTMLElement>("[data-hero-track]");
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"));

  if (slider && track && dots.length > 1) {
    let currentIndex = 0;
    let isDragging = false;
    let dragOffset = 0;
    let startX = 0;
    let startTime = 0;
    let autoplayId: number | undefined;

    function slidesCount() {
      return dots.length;
    }

    function render(animate: boolean) {
      const width = slider.offsetWidth || 1;
      const translatePercent = -currentIndex * 100 + (dragOffset / width) * 100;
      track.style.transition = animate
        ? "transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94)"
        : "transform 0s ease";
      track.style.transform = `translateX(${translatePercent}%)`;
    }

    function updateDots() {
      dots.forEach((dot, i) => dot.classList.toggle("is-active", i === currentIndex));
    }

    function goTo(index: number) {
      currentIndex = (index + slidesCount()) % slidesCount();
      dragOffset = 0;
      render(true);
      updateDots();
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayId = window.setInterval(() => goTo(currentIndex + 1), AUTOPLAY_INTERVAL);
    }

    function stopAutoplay() {
      if (autoplayId) window.clearInterval(autoplayId);
      autoplayId = undefined;
    }

    function dragStart(clientX: number) {
      isDragging = true;
      startX = clientX;
      startTime = Date.now();
      dragOffset = 0;
      stopAutoplay();
      slider.classList.add("is-grabbing");
    }

    function dragMove(clientX: number) {
      if (!isDragging) return;
      dragOffset = clientX - startX;
      render(false);
    }

    function dragEnd() {
      if (!isDragging) return;
      isDragging = false;
      slider.classList.remove("is-grabbing");

      const elapsed = Date.now() - startTime || 1;
      const velocity = Math.abs(dragOffset) / elapsed;

      if (Math.abs(dragOffset) > SWIPE_THRESHOLD || velocity > VELOCITY_THRESHOLD) {
        goTo(currentIndex + (dragOffset < 0 ? 1 : -1));
      } else {
        dragOffset = 0;
        render(true);
      }

      startAutoplay();
    }

    slider.addEventListener("pointerdown", (e) => {
      if (e.button !== 0 && e.pointerType === "mouse") return;
      slider.setPointerCapture(e.pointerId);
      dragStart(e.clientX);
    });

    slider.addEventListener("pointermove", (e) => dragMove(e.clientX));
    slider.addEventListener("pointerup", () => dragEnd());
    slider.addEventListener("pointercancel", () => dragEnd());

    dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

    window.addEventListener("resize", () => render(true));

    startAutoplay();
  }
</script>

<style>
  .hero-slider {
    position: relative;
    width: 100%;
    height: var(--hero-height, 100vh);
    min-height: 480px;
    overflow: hidden;
    background: #000;
    margin-top: -90px;
    cursor: grab;
    touch-action: pan-y;
  }

  .hero-slider.is-grabbing {
    cursor: grabbing;
  }

  @media (max-width: 767px) {
    .hero-slider {
      height: calc(var(--hero-height, 100vh) / 2);
      min-height: 280px;
      margin-top: 0;
    }
  }

  .hero-slider__track {
    display: flex;
    width: 100%;
    height: 100%;
    will-change: transform;
  }

  .hero-slider__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  .hero-slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.35) 100%);
    pointer-events: none;
  }

  .hero-slider__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    text-align: center;
    pointer-events: none;
  }

  .hero-slider__decorated {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .hero-slider__line {
    display: block;
    width: 80px;
    height: 1px;
    background: rgba(255, 255, 255, 0.7);
  }

  @media (min-width: 768px) {
    .hero-slider__line {
      width: 120px;
    }
  }

  .hero-slider__dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .hero-slider__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition:
      background 0.3s ease,
      width 0.3s ease;
  }

  .hero-slider__dot.is-active {
    width: 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
  }
</style>
