---
interface Props {
  slides: string[];
  alt?: string;
  height?: string;
  decorated?: boolean;
}

const { slides, alt = "", height = "100vh", decorated = false } = Astro.props;
---

<section class="hero-slider" style={`--hero-height:${height};`}>
  {
    slides.map((src, index) => (
      <div
        class:list={["hero-slider__slide", index === 0 && "is-active"]}
        style={`background-image:url(${src})`}
        role={index === 0 ? "img" : undefined}
        aria-label={index === 0 ? alt : undefined}
        aria-hidden={index === 0 ? undefined : "true"}
      />
    ))
  }
  <div class="hero-slider__overlay" aria-hidden="true"></div>
  <div class="hero-slider__content">
    {
      decorated ? (
        <div class="hero-slider__decorated">
          <span class="hero-slider__line" />
          <slot />
          <span class="hero-slider__line" />
        </div>
      ) : (
        <slot />
      )
    }
  </div>
  <div class="hero-slider__dots" aria-hidden="true">
    {slides.map((_, i) => <span class:list={["hero-slider__dot", i === 0 && "is-active"]} />)}
  </div>
</section>

<style>
  .hero-slider {
    position: relative;
    width: 100%;
    height: var(--hero-height, 100vh);
    min-height: 480px;
    overflow: hidden;
    background: #000;
    margin-top: -90px;
  }

  .hero-slider__slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    animation: hero-fade 18s infinite;
  }

  .hero-slider__slide:nth-child(1) {
    animation-delay: 0s;
  }

  .hero-slider__slide:nth-child(2) {
    animation-delay: 6s;
  }

  .hero-slider__slide:nth-child(3) {
    animation-delay: 12s;
  }

  .hero-slider__slide:nth-child(4) {
    animation-delay: 18s;
  }

  .hero-slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.35) 100%);
  }

  .hero-slider__content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    text-align: center;
  }

  .hero-slider__decorated {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .hero-slider__line {
    display: block;
    width: 80px;
    height: 1px;
    background: rgba(255, 255, 255, 0.7);
  }

  @media (min-width: 768px) {
    .hero-slider__line {
      width: 120px;
    }
  }

  .hero-slider__dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .hero-slider__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    animation: hero-dot 18s infinite;
  }

  .hero-slider__dot:nth-child(1) {
    animation-delay: 0s;
  }

  .hero-slider__dot:nth-child(2) {
    animation-delay: 6s;
  }

  .hero-slider__dot:nth-child(3) {
    animation-delay: 12s;
  }

  .hero-slider__dot:nth-child(4) {
    animation-delay: 18s;
  }

  @keyframes hero-fade {
    0% {
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    33% {
      opacity: 1;
    }
    38% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @keyframes hero-dot {
    0% {
      background: rgba(255, 255, 255, 0.4);
    }
    5% {
      background: rgba(255, 255, 255, 1);
    }
    33% {
      background: rgba(255, 255, 255, 1);
    }
    38% {
      background: rgba(255, 255, 255, 0.4);
    }
    100% {
      background: rgba(255, 255, 255, 0.4);
    }
  }
</style>
