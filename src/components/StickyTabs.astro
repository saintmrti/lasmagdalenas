---
interface Tab {
  id: string;
  label: string;
}

interface Props {
  tabs: Tab[];
  target?: string;
}

const { tabs, target = "[data-tab-section]" } = Astro.props;
---

<nav class="sticky-tabs" data-sticky-tabs>
  <ul class="sticky-tabs__list">
    {
      tabs.map((tab, i) => (
        <li>
          <a
            href={`#${tab.id}`}
            class:list={["sticky-tabs__link", i === 0 && "is-active"]}
            data-tab-link={tab.id}
          >
            {tab.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("[data-sticky-tabs]");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>("[data-tab-link]");
    const targetSelector = nav.getAttribute("data-target") || "[data-tab-section]";
    const sections = document.querySelectorAll<HTMLElement>(targetSelector);

    if (sections.length > 0) {
      links.forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const id = link.getAttribute("data-tab-link");
          const section = document.getElementById(id ?? "");
          if (section) {
            const offset = nav.offsetHeight + 20;
            const top = section.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top, behavior: "smooth" });
          }
        });
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              links.forEach((link) => {
                link.classList.toggle("is-active", link.getAttribute("data-tab-link") === id);
              });
            }
          });
        },
        {
          rootMargin: `-${nav.offsetHeight + 40}px 0px -60% 0px`,
          threshold: 0,
        }
      );

      sections.forEach((section) => observer.observe(section));
    }
  }
</script>

<style>
  .sticky-tabs {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
    padding: 12px 0;
    transition: top 0.3s ease;
  }

  .sticky-tabs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .sticky-tabs__link {
    display: inline-block;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-soft);
    border: 1px solid transparent;
    transition:
      color 0.2s,
      border-color 0.2s,
      background 0.2s;
  }

  .sticky-tabs__link:hover {
    color: var(--color-accent);
  }

  .sticky-tabs__link.is-active {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .sticky-tabs__link {
      padding: 10px 28px;
      font-size: 0.9rem;
    }
  }
</style>
