---
interface Tab {
  id: string;
  label: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
---

<nav aria-label="Categorías del menú" data-menu-tabs>
  <ul
    class="grid grid-cols-2 border border-line md:border-0 md:flex md:flex-nowrap md:justify-center md:gap-0"
    role="tablist"
  >
    {
      tabs.map((tab, i) => (
        <li
          class="border-b border-line last:border-b-0 odd:border-r md:odd:border-r md:last:border-b md:border-b-0 md:border-r-0"
          role="presentation"
        >
          <a
            href={`#${tab.id}`}
            id={`tab-${tab.id}`}
            class:list={[
              "block px-4 py-3 text-center text-sm font-light text-ink-soft transition-colors hover:text-ink md:border md:border-line md:border-b-0 md:px-6",
              i === 0 && "is-active",
            ]}
            role="tab"
            aria-controls={`panel-${tab.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            data-tab-link={tab.id}
          >
            {tab.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("[data-menu-tabs]");
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>("[data-tab-link]");
    const panels = document.querySelectorAll<HTMLElement>("[data-menu-panel]");

    const activate = (id: string, updateHash = false) => {
      panels.forEach((panel) => {
        panel.hidden = panel.id !== `panel-${id}`;
      });

      links.forEach((link) => {
        const isActive = link.getAttribute("data-tab-link") === id;
        link.classList.toggle("is-active", isActive);
        link.setAttribute("aria-selected", String(isActive));
      });

      if (updateHash) history.replaceState(null, "", `#${id}`);
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        const id = link.getAttribute("data-tab-link");
        if (id) activate(id, true);
      });
    });

    const initialId = window.location.hash.slice(1);
    if (initialId && document.getElementById(`panel-${initialId}`)) activate(initialId);
  }
</script>

<style>
  .is-active {
    color: var(--color-ink);
  }

  @media (min-width: 768px) {
    .is-active {
      position: relative;
      z-index: 1;
      margin-bottom: -1px;
      color: var(--color-ink);
      background: #ffffff;
    }
  }
</style>
