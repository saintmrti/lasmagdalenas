---
interface Props {
  titleImage?: string;
  titleText?: string;
  lead?: string;
  align?: "center" | "left";
}

const { titleImage, titleText, lead, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center";
---

<header class:list={["max-w-3xl mx-auto", alignClass]}>
  {titleImage && <img src={titleImage} alt="" class="max-w-40 mx-auto mb-6" loading="lazy" />}
  {
    titleText && (
      <h2 class="font-display text-3xl md:text-4xl leading-tight font-normal tracking-tighter text-ink-dark mt-5 mb-2.5">
        {titleText}
      </h2>
    )
  }
  {lead && <p class="mx-auto text-ink-soft leading-[1.7]">{lead}</p>}
  <slot />
</header>
