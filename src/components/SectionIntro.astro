---
interface Props {
  titleImage?: string;
  titleText?: string;
  lead?: string;
  align?: "center" | "left";
}

const { titleImage, titleText, lead, align = "center" } = Astro.props;
const alignClass = align === "left" ? "text-left" : "text-center";
---

<header class:list={["mx-auto mb-10", alignClass]}>
  {titleImage && <img src={titleImage} alt="" class="max-w-40 mx-auto mb-6" loading="lazy" />}
  {titleText && <h2 class="font-display text-[1.6rem] md:text-[2rem] tracking-[0.08em] uppercase text-accent-dark mb-5 mt-0">{titleText}</h2>}
  {lead && <p class="max-w-[720px] mx-auto mb-4 text-ink-soft leading-[1.7]">{lead}</p>}
  <slot />
</header>
