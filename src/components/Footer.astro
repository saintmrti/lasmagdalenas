---
import { site, images, social } from "../data/site";
---

<footer class="bg-black/90 text-ink-inverse pt-14 pb-6">
  <div class="container-x grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-6 mb-8">
    <div class="text-center">
      <a href="/" aria-label={site.name}>
        <img src={images.logoFooter} alt={site.name} class="h-28 md:h-40 w-auto mx-auto" />
      </a>
    </div>

    <div class="text-left">
      <h2 class="font-display text-base text-white/70 mt-0">CONTACTO</h2>
      <p class="text-white/70 text-sm">{site.address}</p>

      <a
        href={site.mapsUrl}
        class="inline-block text-xs font-semibold text-white/70 hover:text-accent-dark transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        VER MAPA
      </a>

      <p class="text-sm">
        <a
          href={`tel:${site.phoneTel}`}
          class="text-white/70 hover:text-accent-dark transition-colors">{site.phone}</a
        >
      </p>
      <p class="text-sm">
        <a
          href={`mailto:${site.email}`}
          class="text-white/70 hover:text-accent-dark transition-colors">{site.email}</a
        >
      </p>
    </div>

    <div class="text-center">
      <h3 class="font-display text-base text-white/70 mb-4 mt-0">CONECTE CON NOSOTROS</h3>
      <ul class="list-none flex gap-3.5 justify-center p-0" aria-label="Redes sociales">
        <li>
          <a
            href={social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex items-center justify-center w-9 h-9 border border-white/20 text-ink-inverse hover:text-accent hover:border-accent transition-colors"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07c0 5 3.66 9.13 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22c4.78-.8 8.43-4.93 8.43-9.93Z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex items-center justify-center w-9 h-9 border border-white/20 text-ink-inverse hover:text-accent hover:border-accent transition-colors"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.74 3.74 0 0 1-1.38-.9 3.74 3.74 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 2.16c-3.14 0-3.51.01-4.74.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.27.83-.39.39-.63.76-.83 1.27-.15.39-.33.97-.38 2.04-.06 1.23-.07 1.6-.07 4.74s.01 3.51.07 4.74c.05 1.07.23 1.65.38 2.04.2.51.44.88.83 1.27.39.39.76.63 1.27.83.39.15.97.33 2.04.38 1.23.06 1.6.07 4.74.07s3.51-.01 4.74-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.27-.83.39-.39.63-.76.83-1.27.15-.39.33-.97.38-2.04.06-1.23.07-1.6.07-4.74s-.01-3.51-.07-4.74c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.83-1.27 3.4 3.4 0 0 0-1.27-.83c-.39-.15-.97-.33-2.04-.38C15.51 4.33 15.14 4.32 12 4.32Zm0 3.68a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm0 6.6a2.6 2.6 0 1 0 0-5.2 2.6 2.6 0 0 0 0 5.2Zm5.1-6.76a.96.96 0 1 1-1.92 0 .96.96 0 0 1 1.92 0Z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href={social.tripadvisor}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TripAdvisor"
            class="inline-flex items-center justify-center w-9 h-9 border border-white/20 text-ink-inverse hover:text-accent hover:border-accent transition-colors"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M19.5 7.5h-15A1.5 1.5 0 0 0 3 9v6a1.5 1.5 0 0 0 1.5 1.5h.74a4 4 0 0 0 7.52 0h1.48a4 4 0 0 0 7.52 0h.24A1.5 1.5 0 0 0 21 15V9a1.5 1.5 0 0 0-1.5-1.5Zm-14 8.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Zm9 0a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"
              ></path>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="text-center md:text-right">
      <h3 class="font-display text-base text-white/70 mb-3 mt-0">RECONOCIMIENTOS</h3>
      <div class="flex justify-center md:justify-end items-center gap-4 mb-4">
        <img src={images.distintivoM} alt="Distintivo M" loading="lazy" class="h-16 w-auto" />
        <img src={images.pueblosMagicos} alt="Pueblos Mágicos" loading="lazy" class="h-16 w-auto" />
      </div>
      <div class="flex justify-center md:justify-end items-center">
        <a
          href={social.tripadvisor}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TripAdvisor"
        >
          <img src={images.tripadvisor} alt="TripAdvisor" loading="lazy" class="h-6 w-auto" />
        </a>
      </div>
    </div>
  </div>

  <div class="pt-2 text-center text-sm text-white/60">
    <div class="container-x">
      <p class="m-0">
        © 2017 {site.name}. Design by <a
          href="https://linktr.ee/saintmrti/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-accent-dark transition-colors">Saint-Martín</a
        >
      </p>
    </div>
  </div>
</footer>
