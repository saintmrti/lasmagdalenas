---
interface Props {
  title: string;
  image: string;
  height?: string;
}

const { title, image, height = "60vh" } = Astro.props;
---

<section
  class="page-hero relative w-full min-h-[320px] overflow-hidden text-ink-inverse"
  style={`--page-hero-height:${height};height:var(--page-hero-height, 60vh);`}
>
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image:url(${image})`}
    role="img"
    aria-label={title}
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.15)_0%,rgba(0,0,0,0.45)_100%)]"
    aria-hidden="true"
  >
  </div>
  <div class="container-x relative z-[2] h-full flex items-center justify-center text-center">
    <h1 class="font-display text-4xl md:text-5xl tracking-[0.12em] uppercase text-ink-inverse m-0">
      {title}
    </h1>
  </div>
</section>

<style>
  .page-hero {
    margin-top: -90px;
  }
</style>
