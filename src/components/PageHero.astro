---
interface Props {
  image: string;
  height?: string;
}

const { image, height = "70vh" } = Astro.props;
---

<section
  class="page-hero relative w-full min-h-80 overflow-hidden text-ink-inverse"
  style={`--page-hero-height:${height};height:var(--page-hero-height, 70vh);`}
>
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image:url(${image})`}
    role="img"
    aria-label="Imagen de portada"
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.15)_0%,rgba(0,0,0,0.45)_100%)]"
    aria-hidden="true"
  >
  </div>
</section>

<style>
  .page-hero {
    margin-top: -90px;
  }
</style>